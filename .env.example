# Content Moderation Benchmark - Environment Variables
# Copy this file to .env and fill in your actual credentials
# IMPORTANT: Never commit .env to version control!

# =============================================================================
# Shumei (数美科技)
# =============================================================================
SHUMEI_ACCESS_KEY=your_shumei_access_key_here
SHUMEI_APP_ID=default
SHUMEI_TEXT_URL=https://api-text-bj.fengkongcloud.com/text/v4
SHUMEI_IMAGE_URL=https://api-img-bj.fengkongcloud.com/image/v4

# =============================================================================
# Bytedance (字节跳动)
# =============================================================================
# BYTEDANCE_ACCESS_KEY=your_bytedance_access_key_here
# BYTEDANCE_SECRET_KEY=your_bytedance_secret_key_here
# BYTEDANCE_TEXT_URL=https://xxx.bytedance.com/text
# BYTEDANCE_IMAGE_URL=https://xxx.bytedance.com/image

# =============================================================================
# NetEase Yidun (网易易盾)
# =============================================================================
# YIDUN_SECRET_ID=your_yidun_secret_id_here
# YIDUN_SECRET_KEY=your_yidun_secret_key_here
# YIDUN_BUSINESS_ID=your_business_id_here
# YIDUN_TEXT_URL=https://as.dun.163.com/v5/text/check
# YIDUN_IMAGE_URL=https://as.dun.163.com/v5/image/check

# =============================================================================
# Juntong (君同)
# =============================================================================
# JUNTONG_APP_KEY=your_juntong_app_key_here
# JUNTONG_APP_SECRET=your_juntong_app_secret_here
# JUNTONG_TEXT_URL=https://xxx.juntong.com/text
# JUNTONG_IMAGE_URL=https://xxx.juntong.com/image

# =============================================================================
# Benchmark Configuration
# =============================================================================
# Concurrency settings
MAX_WORKERS=10
REQUEST_INTERVAL=0.1
REQUEST_TIMEOUT=30
RETRY_TIMES=3

# Output settings
OUTPUT_DIR=output
REPORT_DIR=reports
